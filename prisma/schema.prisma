generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ── Enums for core domain ──────────────────────────────────────────────────

enum UserStatus {
  Active
  Inactive
  Suspended
}

enum RestaurantStatus {
  Active
  Inactive
  Suspended
}

enum BranchStatus {
  Active
  Inactive
}

enum DealStatus {
  Draft
  Active
  Expired
}

enum ProductStatus {
  Active
  Inactive
  Archived
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  EASYPaisa
  JAZZCash
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  REFUNDED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

/// Status for sellable menu items
enum MenuItemStatus {
  ACTIVE
  INACTIVE
}

/// ── Platform & tenancy ─────────────────────────────────────────────────────

/// Platform tenant. Each Restaurant is an isolated SaaS tenant that can own
/// many Branches. A Restaurant is created/managed by the Platform Super Admin
/// and is operated by a Restaurant Admin.
model Restaurant {
  restaurant_id         Int      @id @default(autoincrement())
  name                  String
  slug                  String   @unique
  phone                 String?
  address               String?
  status                String   @default("Active")
  /// When false the tenant behaves as a single-branch restaurant: the
  /// Restaurant Admin can't create more branches, the "Branches" module is
  /// hidden in the sidebar, and all operational data flows through a single
  /// default branch created automatically on tenant provisioning.
  has_multiple_branches Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  branches Branch[]
  users    User[]
  orders   Order[]

  @@index([status])
  @@map("restaurants")
}

model Branch {
  branch_id     Int      @id @default(autoincrement())
  branch_name   String
  branch_code   String   @unique
  restaurant_id Int
  address       String?
  city          String   @default("")
  status        String   @default("Active")
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  restaurant  Restaurant  @relation(fields: [restaurant_id], references: [restaurant_id], onDelete: Cascade)
  categories  Category[]
  dayends     DayEnd[]
  menu_items  MenuItem[]
  expenses    Expense[]
  halls       Hall[]
  order_items OrderItem[]
  orders      Order[]
  tables      Table[]
  users       User[]
  deals       Deal[]
  payments    Payment[]

  @@index([restaurant_id])
  @@map("branches")
}

model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique
  password      String
  fullname      String?
  token         String?
  role          String   @default("RESTAURANT_ADMIN")
  restaurant_id Int?
  branch_id     Int?
  status        String   @default("Active")
  /// Legacy single-terminal POS marker. Kept for DB-stable FKs but no longer
  /// surfaced in the UI. Always written as 1 by the current app.
  terminal      Int      @default(1)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  dayends_closed   DayEnd[]    @relation("ClosedBy")
  expenses_created Expense[]   @relation("ExpenseCreatedBy")
  orders_taken     Order[]     @relation("OrderTaker")
  restaurant       Restaurant? @relation(fields: [restaurant_id], references: [restaurant_id])
  branch           Branch?     @relation(fields: [branch_id], references: [branch_id])
  payments         Payment[]

  @@index([restaurant_id])
  @@index([branch_id])
  @@index([username])
  @@map("users")
}

/// ── Floor plan ────────────────────────────────────────────────────────────

model Hall {
  hall_id    Int      @id @default(autoincrement())
  name       String
  capacity   Int      @default(0)
  /// Legacy multi-terminal marker (see User.terminal). Always 1 in the
  /// current app; retained for historical rows.
  terminal   Int      @default(1)
  branch_id  Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  branch Branch   @relation(fields: [branch_id], references: [branch_id])
  orders Order[]
  tables Table[]

  @@index([branch_id])
  @@index([branch_id, terminal])
  @@map("halls")
}

model Table {
  table_id     Int      @id @default(autoincrement())
  table_number String
  hall_id      Int
  branch_id    Int
  terminal     Int      @default(1)
  capacity     Int      @default(0)
  status       String   @default("Available")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  orders Order[]
  branch Branch @relation(fields: [branch_id], references: [branch_id])
  hall   Hall   @relation(fields: [hall_id], references: [hall_id])

  @@unique([hall_id, table_number, branch_id, terminal])
  @@index([branch_id])
  @@index([hall_id])
  @@index([branch_id, terminal])
  @@map("tables")
}

/// ── Menu catalog ───────────────────────────────────────────────────────────

model Category {
  category_id Int      @id @default(autoincrement())
  /// "Kid" flag used to mark inactive categories (0 = active, 1 = inactive).
  /// Named for historical reasons from the desktop POS; kept as-is to avoid
  /// migrating hundreds of existing rows.
  kid         Int      @default(0)
  name        String
  description String?
  terminal    Int      @default(1)
  branch_id   Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  branch     Branch     @relation(fields: [branch_id], references: [branch_id])
  menu_items MenuItem[]

  @@index([branch_id])
  @@index([branch_id, terminal])
  @@map("categories")
}

/// Sellable menu items. Single table for both catalog management (Menu module)
/// and operational usage (order items, deal items, reports).
///
/// The Prisma relation field name is `menu_items` on `Branch` and `Category`,
/// and the physical table name is `menu_items`. The legacy primary key name
/// `dish_id` is preserved so existing FKs on `order_items` and `deal_items`
/// continue to work without data-level changes.
model MenuItem {
  dish_id        Int            @id @default(autoincrement())
  name           String
  description    String?
  price          Decimal        @default(0.00)
  base_price     Decimal?
  has_variations Boolean        @default(false)
  sku            String?
  image          String?
  /// Hide synthetic variant rows (e.g. "Tea (Small)" created by the order
  /// flow) from the Menu module listing.
  show_in_menu   Boolean        @default(true)
  category_id    Int
  /// Legacy single-terminal marker; always 1 in the current app.
  terminal       Int            @default(1)
  branch_id      Int
  status         MenuItemStatus @default(ACTIVE)
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt

  branch      Branch          @relation(fields: [branch_id], references: [branch_id])
  category    Category        @relation(fields: [category_id], references: [category_id], onDelete: Cascade)
  order_items OrderItem[]
  dealItems   DealItem[]
  variations  MenuVariation[]

  @@index([branch_id])
  @@index([category_id])
  @@index([status])
  @@index([created_at])
  @@index([branch_id, terminal])
  @@index([branch_id, category_id])
  @@map("menu_items")
}

/// Named price variations for a menu item (e.g. Small / Medium / Large).
/// `menuId` references `menu_items.dish_id`.
model MenuVariation {
  id        Int      @id @default(autoincrement())
  menuId    Int
  name      String
  price     Decimal  @default(0.00)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menu MenuItem @relation(fields: [menuId], references: [dish_id], onDelete: Cascade)

  @@unique([menuId, name])
  @@index([menuId])
  @@index([sortOrder])
  @@map("menu_item_variations")
}

/// ── Promotions ────────────────────────────────────────────────────────────

/// Promotional deals (branch-specific or global)
model Deal {
  id             Int        @id @default(autoincrement())
  branch_id      Int?
  name           String
  description    String?
  status         DealStatus @default(Active)
  /// "PERCENTAGE" or "FIXED". Free-text today; a DealDiscountType enum is on
  /// the roadmap but kept out of this cleanup to avoid rewrites.
  discount_type  String
  discount_value Decimal    @default(0.0)
  starts_at      DateTime?
  ends_at        DateTime?
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt

  branch Branch?    @relation(fields: [branch_id], references: [branch_id])
  items  DealItem[]

  @@index([branch_id])
}

/// Items included in a deal (ties to menu items).
model DealItem {
  id         Int      @id @default(autoincrement())
  deal_id    Int
  dish_id    Int
  quantity   Int      @default(1)
  created_at DateTime @default(now())

  deal      Deal     @relation(fields: [deal_id], references: [id])
  menu_item MenuItem @relation(fields: [dish_id], references: [dish_id])

  @@unique([deal_id, dish_id])
}

/// ── Orders & payments ─────────────────────────────────────────────────────

model Order {
  order_id         Int         @id @default(autoincrement())
  /// Free-text today ("Dine In" | "Take Away" | "Delivery"). Tightening to
  /// OrderType enum is planned but kept out of this round because dozens of
  /// call sites compare against the raw strings.
  order_type       String      @default("Dine In")
  /// Free-text today (e.g. "Running" | "Served" | "Paid" | "Cancelled").
  /// OrderStatus enum migration is planned; see schema audit.
  order_status     String      @default("Running")
  hall_id          Int?
  table_id         Int?
  comments         String?
  /// Legacy single-terminal marker; always 1 in the current app.
  terminal         Int         @default(1)
  order_taker_id   Int
  branch_id        Int
  restaurant_id    Int
  g_total_amount   Decimal     @default(0.00)
  service_charge   Decimal     @default(0.00)
  discount_amount  Decimal     @default(0.00)
  net_total_amount Decimal     @default(0.00)
  payment_mode     String      @default("Cash")
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  order_items OrderItem[]
  branch      Branch      @relation(fields: [branch_id], references: [branch_id])
  restaurant  Restaurant  @relation(fields: [restaurant_id], references: [restaurant_id])
  hall        Hall?       @relation(fields: [hall_id], references: [hall_id])
  order_taker User        @relation("OrderTaker", fields: [order_taker_id], references: [id])
  table       Table?      @relation(fields: [table_id], references: [table_id])
  payments    Payment[]

  @@index([branch_id])
  @@index([restaurant_id])
  @@index([order_taker_id])
  @@index([table_id])
  @@index([hall_id])
  @@index([branch_id, terminal])
  @@index([restaurant_id, created_at])
  @@index([order_status])
  @@map("orders")
}

model OrderItem {
  item_id      Int     @id @default(autoincrement())
  order_id     Int
  dish_id      Int
  quantity     Decimal @default(1)
  price        Decimal @default(0.00)
  total_amount Decimal @default(0.00)
  branch_id    Int

  branch    Branch   @relation(fields: [branch_id], references: [branch_id])
  menu_item MenuItem @relation(fields: [dish_id], references: [dish_id])
  order     Order    @relation(fields: [order_id], references: [order_id])

  @@index([order_id])
  @@index([dish_id])
  @@index([branch_id])
  @@map("order_items")
}

/// Payments for orders (supports multiple methods / future split payments).
model Payment {
  id            Int           @id @default(autoincrement())
  order_id      Int
  branch_id     Int
  amount        Decimal       @default(0.00)
  method        PaymentMethod
  status        PaymentStatus @default(PAID)
  reference     String?
  paid_at       DateTime      @default(now())
  created_at    DateTime      @default(now())
  created_by_id Int?

  order      Order  @relation(fields: [order_id], references: [order_id])
  branch     Branch @relation(fields: [branch_id], references: [branch_id])
  created_by User?  @relation(fields: [created_by_id], references: [id])

  @@index([order_id])
  @@index([branch_id])
  @@index([method])
  @@index([status])
}

/// ── Expenses & day end ────────────────────────────────────────────────────

model Expense {
  id                Int              @id @default(autoincrement())
  title             String
  amount            Decimal          @default(0.00)
  description       String?
  branch_id         Int?
  terminal          Int              @default(1)
  payment_method    String?
  expense_date      DateTime         @default(now())
  created_by_id     Int?
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  expenseCategoryId Int?

  branch          Branch?          @relation(fields: [branch_id], references: [branch_id])
  expenseCategory ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id])
  created_by      User?            @relation("ExpenseCreatedBy", fields: [created_by_id], references: [id])

  @@index([branch_id])
  @@index([branch_id, terminal])
  @@index([expenseCategoryId])
  @@index([created_by_id])
  @@map("expenses")
}

model ExpenseCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  expenses Expense[]
}

model DayEnd {
  id                Int      @id @default(autoincrement())
  branch_id         Int
  /// Business day this closure represents (calendar date, branch-local).
  /// Combined with branch_id it is unique so a given branch/day can only be
  /// closed once.
  business_date     DateTime @default(now()) @db.Date
  opening_balance   Decimal  @default(0.00)
  total_expenses    Decimal  @default(0.00)
  total_cash        Decimal  @default(0.00)
  total_easypaisa   Decimal  @default(0.00)
  total_bank        Decimal  @default(0.00)
  credit_sales      Decimal  @default(0.00)
  total_sales       Decimal  @default(0.00)
  total_receivings  Decimal  @default(0.00)
  drawings          Decimal  @default(0.00)
  closing_balance   Decimal  @default(0.00)
  /// Booked order count captured at closure time (fast listing).
  total_orders      Int      @default(0)
  /// Cancelled order count captured at closure time.
  cancelled_orders  Int      @default(0)
  closing_date_time DateTime @default(now())
  closing_by        Int      @default(0)
  note              String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  branch    Branch @relation(fields: [branch_id], references: [branch_id])
  closed_by User   @relation("ClosedBy", fields: [closing_by], references: [id])

  @@unique([branch_id, business_date])
  @@index([branch_id])
  @@index([business_date])
  @@index([closing_date_time])
  @@map("dayend")
}
